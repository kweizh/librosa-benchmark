{"type":"message-part","timestamp":"2026-06-13T11:23:43.590Z","messageId":"0358b47f-1fa0-415e-b849-4f1549dcece7","role":"assistant","index":5,"part":{"type":"tool-writeToFile","toolCallId":"tNF0n5PUNsZzQIZ6","state":"output-available","input":{"path":"/workspace/mosaic.py","content":"import librosa\nimport numpy as np\nimport soundfile as sf\nfrom sklearn.metrics.pairwise import cosine_similarity\n\ntarget_y, target_sr = librosa.load('/workspace/target.wav', sr=None)\nsource_y, source_sr = librosa.load('/workspace/source.wav', sr=None)\n\nframe_length = 2048\n\ntarget_n_frames = len(target_y) // frame_length\nsource_n_frames = len(source_y) // frame_length\n\ntarget_frames = np.array([target_y[i*frame_length:(i+1)*frame_length] for i in range(target_n_frames)])\nsource_frames = np.array([source_y[i*frame_length:(i+1)*frame_length] for i in range(source_n_frames)])\n\ndef get_mfcc(frames, sr):\n    mfccs = []\n    for f in frames:\n        m = librosa.feature.mfcc(y=f, sr=sr, n_fft=2048, hop_length=2048, center=False)\n        mfccs.append(m.flatten())\n    return np.array(mfccs)\n\ntarget_mfcc = get_mfcc(target_frames, target_sr)\nsource_mfcc = get_mfcc(source_frames, source_sr)\n\nsim = cosine_similarity(target_mfcc, source_mfcc)\nbest_source_indices = np.argmax(sim, axis=1)\n\nmosaic_frames = source_frames[best_source_indices]\nmosaic_y = mosaic_frames.flatten()\n\nsf.write('/workspace/mosaic.wav', mosaic_y, target_sr)\n"},"output":{"success":true},"callProviderMetadata":{"vertex":{"thoughtSignature":""}}}}
